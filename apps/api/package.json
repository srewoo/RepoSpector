{
  "name": "@repospector/api",
  "version": "0.1.0",
  "description": "Aegis — RepoSpector backend service. Fastify API + BullMQ worker.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/workers/reviewWorker.js",
